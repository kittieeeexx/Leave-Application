rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "sales@creativoom.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'employee'] &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('attendanceId' in data) || data.attendanceId is string) &&
             (!('salaryType' in data) || data.salaryType in ['daily', 'monthly']) &&
             (!('baseSalary' in data) || data.baseSalary is number);
    }

    function isValidAttendanceRecord(data) {
      return data.keys().hasAll(['userId', 'attendanceId', 'date']) &&
             data.userId is string &&
             data.attendanceId is string &&
             data.date is string &&
             (!('clockIn' in data) || data.clockIn is string) &&
             (!('clockOut' in data) || data.clockOut is string) &&
             (!('workHours' in data) || data.workHours is number);
    }

    function isValidPayrollRecord(data) {
      return data.keys().hasAll(['userId', 'month', 'calculatedSalary', 'status']) &&
             data.userId is string &&
             data.month is string &&
             data.calculatedSalary is number &&
             data.status in ['draft', 'paid'] &&
             (!('totalDays' in data) || data.totalDays is number) &&
             (!('totalHours' in data) || data.totalHours is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow user to create their own profile as employee, or admin can create any
      allow create: if isAuthenticated() && isValidUser(request.resource.data) &&
                    ((isOwner(userId) && request.resource.data.role == 'employee' && request.resource.data.uid == userId) || isAdmin());
      
      // Allow user to update their own profile (but not sensitive fields), or admin can update any
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                    ((isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.get('attendanceId', '') == resource.data.get('attendanceId', '') &&
                      request.resource.data.get('salaryType', '') == resource.data.get('salaryType', '') &&
                      request.resource.data.get('baseSalary', 0) == resource.data.get('baseSalary', 0)) || 
                     isAdmin());
                     
      allow delete: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() && isValidAttendanceRecord(request.resource.data);
      allow update: if isAdmin() && isValidAttendanceRecord(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payroll_records/{recordId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() && isValidPayrollRecord(request.resource.data);
      allow update: if isAdmin() && isValidPayrollRecord(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
